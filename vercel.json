{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    {
      "source": "/buildingos/:path*",
      "destination": "https://buildingos.piassa.ai/:path*"
    },
    {
      "source": "/fieldcapture/:path*",
      "destination": "https://fieldcapture.piassa.ai/:path*"
    },
    {
      "source": "/config/:path*",
      "destination": "https://buildingos.piassa.ai/config/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://buildingos.piassa.ai/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://buildingos.piassa.ai/health"
    },
    {
      "source": "/documents/:path*",
      "destination": "https://buildingos.piassa.ai/documents/:path*"
    },
    {
      "source": "/buildings/:path*",
      "destination": "https://buildingos.piassa.ai/buildings/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
